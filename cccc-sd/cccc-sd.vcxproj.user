    <LocalDebuggerCommandArguments>--sd -c . -p "orange cat"</LocalDebuggerCommandArguments>
    <LocalDebuggerWorkingDirectory>C:\project\cccc-models\cccc-sd\z-image-turbo</LocalDebuggerWorkingDirectory>
